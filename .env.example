# Скопируйте в .env и задайте свои значения:  cp .env.example .env
# Внешний порт приложения (http://СЕРВЕР:APP_PORT)
APP_PORT=8080

# База данных
DB_NAME=uchet
DB_USER=uchet
DB_PASS=ЗАМЕНИТЕ_НА_СИЛЬНЫЙ_ПАРОЛЬ

# Демо-данные при первом запуске: 1 — создать (вход admin/admin123), 0 — не создавать
SEED_DEMO=1
