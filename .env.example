# Скопируйте в .env и задайте значения:  cp .env.example .env

# Домен для Traefik (роутер по Host)
CORP_HOST=corp.example.org

# Часовой пояс (для корректных дат и расчёта «по 25-е»)
TZ=Europe/Moscow

# База данных
DB_NAME=uchet
DB_USER=uchet
DB_PASS=ЗАМЕНИТЕ_НА_СИЛЬНЫЙ_ПАРОЛЬ

# Демо-данные при первом запуске: 1 — создать (вход admin/admin123), 0 — не создавать
SEED_DEMO=1
